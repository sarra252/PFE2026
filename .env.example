APP_NAME=Teradata SQL Copilot
APP_VERSION=0.1.0
LOG_LEVEL=INFO
API_KEY=changeme

LLM_MODE=mock
LLM_TIMEOUT_S=30
LLM_FALLBACK_TO_MOCK=true
